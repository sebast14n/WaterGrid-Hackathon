elif view_mode == "🗺️ Map & Imagery":
    
    if aoi_info:
        st.subheader(f"🗺️ Map — {aoi_info['name']}")
        
        # Map with AOI
        m = folium.Map(
            location=[aoi_info['centroid']['lat'], aoi_info['centroid']['lon']],
            zoom_start=15,
            tiles='https://tiles.maps.eox.at/wmts/1.0.0/s2cloudless-2021_3857/default/g/{z}/{y}/{x}.jpg',
            attr='Sentinel-2 cloudless – s2maps.eu by EOX'
        )
        
        folium.GeoJson(
            aoi_info['geojson'],
            name="Monitored zone",
            style_function=lambda _: {"color": "#dc2626", "weight": 3, "fillColor": "#dc2626", "fillOpacity": 0.2}
        ).add_to(m)
        
        folium.LayerControl().add_to(m)
        st_folium(m, height=500, use_container_width=True)
    
    st.markdown("---")
    
    # Imagery gallery
    st.subheader("🖼️ Sentinel-2 imagery — by month")
    
    images = fetch_api(f"/scene-images/{KMZ_ID}")
    if images:
        # Group by month, take best (lowest cloud)
        df_img = pd.DataFrame(images)
        df_img['month'] = df_img['date'].str[:7]
        
        # Best per month
        best_per_month = df_img.sort_values('cloud_cover').groupby('month').first().reset_index()
        best_per_month = best_per_month.sort_values('month')
        
        st.markdown(f"**{len(best_per_month)} monthly composites** — best cloud-free scene per month")
        
        # Show selectable view
        view_type = st.selectbox("Imagery type", ["RGB true color", "NDVI (vegetation)", "NDWI (water)"])
        url_field = {"RGB true color": "rgb_url", "NDVI (vegetation)": "ndvi_url", "NDWI (water)": "ndwi_url"}[view_type]
        
        # Grid of images
        n_cols = 4
        for i in range(0, len(best_per_month), n_cols):
            cols = st.columns(n_cols)
            for j, col in enumerate(cols):
                if i + j < len(best_per_month):
                    row = best_per_month.iloc[i + j]
                    with col:
                        if row[url_field]:
                            st.image(row[url_field], caption=f"{row['month']}", use_container_width=True)
                            st.caption(f"NDVI: {row['ndvi']} | BSI: {row['bsi']} | Water: {row['water_pct']}%")


elif view_mode == "🚨 Alerts & Reports":
    
    st.subheader("🚨 Detected anomalies")
    st.markdown("Anomalies are flagged when monthly indices deviate significantly (z-score > 1.0) from the 12-month baseline.")
    
    alerts_data = fetch_api(f"/alerts/{KMZ_ID}")
    
    if alerts_data and alerts_data['alerts']:
        for alert in alerts_data['alerts']:
            sev = alert['severity']
            css_class = f"alert-{sev}"
            
            with st.container():
                st.markdown(f"""
                <div class="{css_class}">
                    <strong>{alert['month']}</strong> — Severity: {sev.upper()} (max z-score: {alert['max_z']})
                    <br>NDVI: {alert['ndvi']} (z={alert['ndvi_z']}) | BSI: {alert['bsi']} (z={alert['bsi_z']}) | NDWI: {alert['ndwi']} (z={alert['ndwi_z']})
                </div>
                """, unsafe_allow_html=True)
                
                col1, col2 = st.columns([3, 1])
                with col2:
                    if st.button(f"📄 Generate report", key=f"report_{alert['month']}"):
                        with st.spinner("Generating official report via Claude..."):
                            report = fetch_post(f"/alerts/{KMZ_ID}/{alert['month']}/report")
                            if report:
                                st.session_state[f"report_{alert['month']}"] = report
                
                if f"report_{alert['month']}" in st.session_state:
                    rep = st.session_state[f"report_{alert['month']}"]
                    with st.expander(f"📄 Official report — {alert['month']}", expanded=True):
                        st.markdown(rep['report'])
                        st.markdown("---")
                        st.caption(f"Generated by Claude (Anthropic) — Data: {rep['metadata']['data_source']}")
                        st.download_button(
                            "Download as text",
                            rep['report'],
                            file_name=f"watergrid_report_{alert['month']}.txt"
                        )
                
                st.markdown("---")
    else:
        st.info("No anomalies detected with current thresholds.")


elif view_mode == "📹 Drone Evidence":
    
    st.subheader("📹 Ground truth — Drone footage")
    st.markdown("""
    Drone footage validates the satellite-detected anomalies on the ground.
    Drone position is georeferenced using **Galileo GNSS + EGNOS** for sub-metric accuracy,
    enabling exact correspondence with Sentinel-2 pixels.
    """)
    
    # Static placeholder - replace with actual video upload
    st.warning("📌 Place drone video files in `/data/drone/drone_*.mp4` and they'll appear here.")
    
    # If drone videos exist
    drone_dir = "/data/drone"
    if os.path.exists(drone_dir):
        videos = [f for f in os.listdir(drone_dir) if f.endswith('.mp4')]
        if videos:
            for video in sorted(videos):
                st.markdown(f"**{video.replace('_', ' ').replace('.mp4', '').title()}**")
                st.video(f"/drone/{video}")
                st.markdown("---")
    
    st.markdown("""
    ### Documented evidence (sample frames)
    
    The drone footage documents:
    - 🚛 Trucks dumping construction debris into former excavation pools
    - 🏗️ Active illegal aggregate extraction operations  
    - ♻️ Floating waste covering water surfaces
    - 🌊 Sediment plumes affecting water quality downstream
    
    Each clip is timestamped and georeferenced for use as legal evidence.
    """)


elif view_mode == "ℹ️ About":
    
    st.subheader("ℹ️ About WaterGrid")
    
    col1, col2 = st.columns(2)
    
    with col1:
        st.markdown("""
        ### The problem
        
        Romania has 600+ Natura 2000 sites covering ~23% of the country.
        These protected ecosystems are increasingly under pressure from illegal activities:
        
        - 🏗️ Unauthorized aggregate extraction (balastiere)
        - 🗑️ Construction debris dumping
        - 💧 River bed alteration
        - 🌳 Habitat destruction
        
        Authorities (Garda de Mediu, Apele Române) cannot physically monitor every site.
        Field inspections happen rarely — disturbances often go undetected for years.
        
        ### Our solution
        
        WaterGrid uses **only public European space infrastructure** to provide
        continuous, automated monitoring of protected sites:
        """)
    
    with col2:
        st.markdown("""
        ### European data sources
        
        🛰️ **Copernicus Sentinel-2**  
        Optical multispectral imagery, 10m resolution, 5-day revisit.
        Provides NDVI (vegetation), BSI (bare soil), NDWI (water) indices.
        
        📡 **Galileo GNSS**  
        Drone georeferencing for sub-metric ground-truth validation.
        
        🛰️ **EGNOS**  
        Augmentation system for improved GNSS accuracy in Natura 2000 zones.
        
        🤖 **Anthropic Claude**  
        LLM-generated official reports for environmental authorities.
        
        ### Pilot site
        
        ROSCI0434 - Siretul Mijlociu  
        ~30 km² of riverbank ecosystem  
        Subset analyzed: 33 ha around documented illegal balastiera
        """)
    
    st.markdown("---")
    
    st.markdown("""
    ### Architecture
    
    - **Distributed processing:** Celery workers on multiple nodes (fsn1, fsn2)
    - **Geospatial database:** PostGIS for time series + spatial queries
    - **Real-time API:** Flask + Gunicorn for serving processed data
    - **Interactive UI:** Streamlit + Folium for monitoring dashboard
    - **Historical baseline:** 24 months of Sentinel-2 (April 2024 - April 2026), 107 scenes processed
    
    ### Roadmap
    
    - 🔄 Phase 2: Sentinel-1 SAR for cloud-penetrating monitoring
    - 🔄 Phase 3: Landsat 8/9 historical backfill (2013+)
    - 🔄 Phase 4: Extension to all 600+ Romanian Natura 2000 sites
    - 🔄 Phase 5: Multi-country deployment via LIFE Programme grant
    """)
