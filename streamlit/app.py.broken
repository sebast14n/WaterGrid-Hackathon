        fig = make_subplots(
            rows=2, cols=1,
            subplot_titles=("Vegetation & Soil indicators (NDVI / BSI)", "Water surface (NDWI / Water %)"),
            vertical_spacing=0.15,
            specs=[[{"secondary_y": False}], [{"secondary_y": True}]]
        )
        
        # NDVI/BSI
        fig.add_trace(
            go.Scatter(x=df['month'], y=df['ndvi'], name='NDVI (vegetation)',
